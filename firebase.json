{
  "hosting": {
    "public": "build/web",
    "ignore": [
      "firebase.json",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "/rsvp.html",
        "destination": "/rsvp.html"
      },
      {
        "source": "/accept.html",
        "destination": "/accept.html"
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  }
}
